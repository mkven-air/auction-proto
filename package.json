    "react-router-dom": "^7.16.0",
    "shadcn": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
