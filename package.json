{
  "name": "auction-proto",
  "private": true,
  "version": "0.1.0",
  "author": "Damir Manapov",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @auction/web dev",
    "dev:api": "pnpm --filter @auction/server dev",
    "start:api": "pnpm --filter @auction/server start",
    "build": "pnpm --filter @auction/web build",
    "preview": "pnpm --filter @auction/web preview",
    "format": "biome format --write . --css-parse-tailwind-directives=true",
    "lint": "biome lint . --error-on-warnings --css-parse-tailwind-directives=true",
    "typecheck": "tsc -b",
    "typecheck:tests": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "bun-types": "^1.3.14",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.4.0",
  "simple-git-hooks": {
    "pre-commit": "bash all-checks.sh"
  }
}
